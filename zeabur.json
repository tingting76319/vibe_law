{
  "$schema": "https://schema.zeabur.com/zeabur.json",
  "build": {
    "backend": {
      "buildCommand": "cd backend && npm install",
      "installCommand": "cd backend && npm install",
      "outputDir": "backend/dist"
    }
  },
  "deploy": {
    "backend": {
      "domain": [
        {
          "hostname": "vibe-law",
          "type": "rewrite"
        }
      ],
      "env": [
        {
          "key": "NODE_ENV",
          "value": "production"
        }
      ],
      "region": "Taiwan"
    }
  }
}
