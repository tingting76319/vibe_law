{
  "$schema": "https://schema.zeabur.com/zeabur.json",
  "build": {
    "backend": {
      "buildCommand": "npm install",
      "installCommand": "npm install"
    }
  },
  "deploy": {
    "backend": {
      "domain": [
        {
          "hostname": "vibe-law"
        }
      ],
      "source": {
        "path": ".",
        "startCommand": "node backend/src/index.js"
      }
    }
  },
  "cron": [
    {
      "name": "update-case-type-stats",
      "command": "node backend/src/scripts/updateCaseTypeStats.js",
      "schedule": "0 3 * * *",
      "description": "每天凌晨 3 點更新判決分類統計"
    }
  ],
  "env": [
    {
      "key": "DATABASE_URL",
      "value": "postgresql://root:p0lK6P4cLAVy82H371bOE9xviMq5CQrY@150.109.204.13:32317/zeabur"
    },
    {
      "key": "NODE_ENV",
      "value": "production"
    },
    {
      "key": "MMKey_LAW_LLM",
      "value": "YOUR_LLM_API_KEY"
    },
    {
      "key": "JUDICIAL_USER",
      "value": "YOUR_JUDICIAL_USERNAME"
    },
    {
      "key": "JUDICIAL_PASSWORD",
      "value": "YOUR_JUDICIAL_PASSWORD"
    }
  ]
}
