{
  "$schema": "https://schema.zeabur.com/zeabur.json",
  "build": {
    "backend": {
      "buildCommand": "npm install --prefix backend && npm run db:init --prefix backend",
      "installCommand": "npm install --prefix backend"
    }
  },
  "deploy": {
    "backend": {
      "domain": [
        {
          "hostname": "vibe-law"
        }
      ],
      "source": {
        "path": ".",
        "startCommand": "node backend/src/index.js"
      }
    }
  }
}
