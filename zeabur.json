{
  "$schema": "https://schema.zeabur.com/zeabur.json",
  "build": {
    "backend": {
      "buildCommand": "cd backend && npm install",
      "installCommand": "cd backend && npm install",
      "outputDir": "backend"
    }
  },
  "deploy": {
    "backend": {
      "domain": [
        {
          "hostname": "vibe-law"
        }
      ],
      "env": [
        {
          "key": "MMKey_LAW_LLM",
          "value": "your-api-key-here"
        }
      ],
      "region": "auto"
    }
  }
}
