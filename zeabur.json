{
  "$schema": "https://schema.zeabur.com/zeabur.json",
  "build": {
    "backend": {
      "buildCommand": "cd backend && npm install && npm run db:init",
      "installCommand": "cd backend && npm install",
      "root": "backend"
    }
  },
  "deploy": {
    "backend": {
      "domain": [
        {
          "hostname": "vibe-law"
        }
      ],
      "source": {
        "path": "backend",
        "startCommand": "npm start"
      },
      "env": [
        {
          "key": "NODE_ENV",
          "value": "production"
        }
      ]
    }
  }
}
