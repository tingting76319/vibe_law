    "calculation_formula": {
      "description": "計算每種風格的分數",
      "steps": [
        "1. 對輸入文字進行分詞處理",
        "2. 逐一檢測關鍵詞是否出現",
        "3. 將出現的關鍵詞權重累加",
        "4. 計算每種風格的總分"
      ],
      "formula": {
        "style_score": "Σ(keyword_weight × keyword_count)",
        "normalization": "style_score / total_keywords_in_style × 100",
        "final_score": "normalization × style_type_multiplier"
      },
      "style_type_multiplier": {
        "攻擊型": 1.2,
        "防禦型": 1.1,
        "妥協型": 1.0,
        "穩健型": 1.15
      }
    },
    
    "judgment_logic": {
      "description": "根據計算結果判定最終風格",
      "threshold": {
        "min_confidence": 0.15,
        "tie_breaker_multiplier": 1.1
      },
      "decision_tree": {
        "step1": "計算四種風格的分數",
        "step2": "找出最高分風格",
        "step3": "檢查最高分是否大於等於門檻值(15%)",
        "step4": "若有風格分數相同(差距<10%)，應用加成係數",
        "step5": "輸出最終風格及其信心度"
      },
      "output_format": {
        "primary_style": "string",
        "confidence": "float (0-1)",
        "all_scores": {
          "攻擊型": "float",
          "防禦型": "float",
          "妥協型": "float",
          "穩健型": "float"
        },
        "reason": "string"
      }
    },
    
    "example": {
      "input_text": "對方主張顯然缺乏依據，其論點自相矛盾，且未提出任何有利證據。依法應當駁回其請求。",
      "analysis": {
        "detected_keywords": {
          "攻擊型": ["缺乏", "自相矛盾", "有利", "應當", "駁回"],
          "防禦型": ["依法", "請求"],
          "妥協型": [],
          "穩健型": ["依法", "依據", "缺乏"]
        },
        "scores": {
          "攻擊型": 8.5,
          "防禦型": 2.8,
          "妥協型": 0.0,
          "穩健型": 4.0
        },
        "result": {
          "primary_style": "攻擊型",
          "confidence": 0.58,
          "reason": "文本中'缺乏依據'、'自相矛盾'、'有利證據'等攻擊性詞彙密集，明顯表現出質疑反駁的攻擊型風格"
        }
      }
    }
  }
