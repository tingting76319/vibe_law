{
  "lawyer_style_standard": {
    "version": "1.0",
    "description": "律師風格判斷標準 - 用於分析法律文本或回覆的風格傾向",
    
    "style_types": {
      "攻擊型": {
        "description": "主動出擊，質疑對方論點，尋找漏洞，強勢表達立場",
        "characteristics": [
          "質疑對手論點",
          "強調己方優勢",
          "引用有利證據",
          "質問對方瑕疵"
        ]
      },
      "防禦型": {
        "description": "穩守立場，反駁攻擊，保護己方論點，謹慎應對",
        "characteristics": [
          "反駁對方指控",
          "強調程序正當",
          "保護當事人權益",
          "降低風險陳述"
        ]
      },
      "妥協型": {
        "description": "尋求共識，願意讓步，注重雙贏，柔性協調",
        "characteristics": [
          "表達合作意願",
          "提出折中方案",
          "尋求共識點",
          "柔性表達立場"
        ]
      },
      "穩健型": {
        "description": "客觀分析，證據為本，邏輯嚴謹，不偏不倚",
        "characteristics": [
          "引用法條依據",
          "客觀陳述事實",
          "分析利弊得失",
          "謹慎下結論"
        ]
      }
    },
    
    "keyword_weights": {
