{
  "name": "vibe-law",
  "version": "1.0.0",
  "description": "台灣法律專家知識系統",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "lint": "eslint js/",
    "lint:fix": "eslint js/ --fix",
    "build": "echo 'No build needed for static frontend'",
    "dev": "node backend/src/index.js",
    "dev:watch": "node --watch backend/src/index.js",
    "ci": "npm run lint && npm run test:run && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^9.39.3",
    "supertest": "^7.2.2",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "morgan": "^1.10.0",
    "uuid": "^11.0.5"
  }
}
